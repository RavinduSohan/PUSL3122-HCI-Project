{
  "name": "furniture-visualiser-backend",
  "version": "1.0.0",
  "description": "PUSL3122 Furniture Room Visualiser — Express API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
